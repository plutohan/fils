{
  "name": "@fils/core",
  "version": "0.1.0",
  "description": "AED (UAE dirham) payments SDK for Solana: token registry, fils-precise amounts, Solana Pay-compatible payment requests, on-chain verification, receipts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plutohan/fils.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@solana/kit": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
