{
  "name": "@fils/einvoice",
  "version": "0.1.0",
  "description": "UAE PINT AE (Peppol) e-invoice XML from Fils receipts for Solana-settled sales: a structurally faithful draft to validate with your accredited service provider",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plutohan/fils.git",
    "directory": "packages/einvoice"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@fils/core": "workspace:*"
  },
  "devDependencies": {
    "@solana/kit": "^6.10.0",
    "@types/node": "^24.13.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
